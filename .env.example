# Copy to .env and customize before running in production.

OPENSEARCH_ADMIN_USERNAME=admin
OPENSEARCH_ADMIN_PASSWORD=ChangeMeNow!

# OpenSearch endpoint for collectors
OPENSEARCH_HOST=127.0.0.1
OPENSEARCH_PORT=9200
OPENSEARCH_SSL_VERIFY=false
OPENSEARCH_DASHBOARDS_SSL_VERIFICATIONMODE=none

# SNMP trap receiver (Logstash)
SNMP_TRAP_COMMUNITY=public

# Grafana frontend
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMeGrafana!

# Redis — enrichment cache (IP reputation, threat intel lookups)
REDIS_PASSWORD=RedisChangeMe!

# JVM tuning
OPENSEARCH_JAVA_OPTS=-Xms4g -Xmx4g
LS_JAVA_OPTS=-Xms2g -Xmx2g
