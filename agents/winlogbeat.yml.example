# Winlogbeat example for Microsoft Windows endpoints
# Install Winlogbeat on endpoint, then point output.logstash.hosts to this stack.

winlogbeat.event_logs:
  - name: Security
  - name: Application
  - name: System
  - name: Microsoft-Windows-Sysmon/Operational

processors:
  - add_host_metadata: ~
  - add_cloud_metadata: ~

output.logstash:
  hosts: ["YOUR_STACK_IP:5044"]

setup.ilm.enabled: false
setup.template.enabled: false
