# Filebeat example for Linux endpoints

filebeat.inputs:
  - type: filestream
    id: linux-system-logs
    enabled: true
    paths:
      - /var/log/syslog
      - /var/log/messages
      - /var/log/auth.log
      - /var/log/secure

processors:
  - add_host_metadata: ~
  - add_cloud_metadata: ~

output.logstash:
  hosts: ["YOUR_STACK_IP:5044"]

setup.ilm.enabled: false
setup.template.enabled: false
